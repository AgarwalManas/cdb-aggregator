# Copy to .env and adjust as needed. All vars are prefixed CDB_.
# Nothing secret lives here yet; later phases (audit-log DB, mock-provider URLs)
# will add entries.

CDB_APP_NAME="Consumer-Driven Banking Aggregator"
CDB_ENVIRONMENT="local"
CDB_DEBUG=true
CDB_HOST="127.0.0.1"
CDB_PORT=8000

# Mock provider base URLs — consumed by the Item 5 adapters.
CDB_PROVIDER_FDX_BASE_URL="http://127.0.0.1:9001"     # clean FDX bank (Item 3)
CDB_PROVIDER_LEGACY_BASE_URL="http://127.0.0.1:9002"  # messy legacy bank (Item 4)
